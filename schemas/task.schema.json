{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:wuditask:schema:task:v3",
  "title": "WudiTask task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "repo",
    "source",
    "created_by",
    "priority",
    "created_at",
    "dependencies",
    "active_agents"
  ],
  "properties": {
    "schema_version": {"const": 3},
    "id": {
      "type": "string",
      "pattern": "^WDT-[0-9]{8}T[0-9]{6}Z-[0-9A-F]{6}$"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "source": {
      "oneOf": [
        {"$ref": "#/$defs/githubIssueSource"},
        {"$ref": "#/$defs/githubPullRequestSource"},
        {"$ref": "#/$defs/githubFallbackIssueSource"}
      ]
    },
    "created_by": {"$ref": "#/$defs/login"},
    "priority": {"enum": ["P0", "P1", "P2", "P3"]},
    "created_at": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^WDT-[0-9]{8}T[0-9]{6}Z-[0-9A-F]{6}$"
      }
    },
    "active_agents": {
      "type": "array",
      "items": {"$ref": "#/$defs/agent"}
    },
    "completion": {"$ref": "#/$defs/completion"}
  },
  "allOf": [
    {
      "if": {"required": ["completion"]},
      "then": {"properties": {"active_agents": {"maxItems": 0}}}
    }
  ],
  "$defs": {
    "login": {"type": "string", "minLength": 1},
    "githubIssueSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "repo", "number"],
      "properties": {
        "kind": {"const": "github_issue"},
        "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "number": {"type": "integer", "minimum": 1}
      }
    },
    "githubPullRequestSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "repo", "number"],
      "properties": {
        "kind": {"const": "github_pull_request"},
        "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "number": {"type": "integer", "minimum": 1}
      }
    },
    "githubFallbackIssueSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "repo", "number", "fallback_reason"],
      "properties": {
        "kind": {"const": "github_issue_fallback"},
        "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "number": {"type": "integer", "minimum": 1},
        "fallback_reason": {"type": "string", "minLength": 1}
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "run_id"],
      "properties": {
        "login": {"$ref": "#/$defs/login"},
        "run_id": {"type": "string", "pattern": "^WDX-[0-9A-F]{24}$"}
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "completed_at",
        "completed_by",
        "result",
        "evidence",
        "participants"
      ],
      "properties": {
        "outcome": {"enum": ["done", "failed", "cancelled"]},
        "completed_at": {"type": "string", "format": "date-time", "pattern": "Z$"},
        "completed_by": {"$ref": "#/$defs/login"},
        "result": {"type": "string", "minLength": 1},
        "evidence": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "participants": {
          "type": "array",
          "items": {"$ref": "#/$defs/agent"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"outcome": {"const": "done"}}},
          "then": {
            "properties": {
              "evidence": {"minItems": 1},
              "participants": {"minItems": 1}
            }
          }
        }
      ]
    }
  }
}
